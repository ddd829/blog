---
import Base from './Base.astro';
import '../styles/prose.css';
import '../styles/prose-essay.css';
interface Props { frontmatter: { title: string; description?: string } }
const { frontmatter } = Astro.props;
---
<Base title={frontmatter.title} description={frontmatter.description}>
  <main class="container">
    <header class="head">
      <h1 class="name">{frontmatter.title}</h1>
    </header>
    <article class="prose prose-essay page-prose"><slot /></article>
  </main>
</Base>

<style>
  .head { padding: 64px 0 40px; }
  .name { font-family: var(--font-display); font-size: 44px; font-weight: 500; margin: 0; }
  .page-prose { max-width: calc(var(--w-essay) + 96px); }
</style>
