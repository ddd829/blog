---
import type { MarkdownHeading } from 'astro';
interface Props { headings: MarkdownHeading[]; label?: string }
const { headings, label = '目录' } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
{items.length > 1 && (
  <nav class="toc" data-toc aria-label="目录">
    <div class="toc-label">{label}</div>
    {items.map((h) => (
      <a href={`#${h.slug}`} class:list={['toc-item', `d${h.depth}`]} data-target={h.slug}>{h.text}</a>
    ))}
  </nav>
)}

<style>
  .toc { font-family: var(--font-ui); font-size: 14px; font-weight: 400; }
  .toc-label {
    font-size: 12px; letter-spacing: 0.16em; color: var(--dim);
    margin-bottom: 12px; font-weight: 600;
  }
  .toc-item {
    display: block; color: var(--dim); text-decoration: none;
    font-size: 14px; line-height: 1.75; padding: 6px 0 6px 14px;
    border-left: 1px solid var(--hair);
  }
  .toc-item.d3 { padding-left: 26px; }
  .toc-item:hover { color: var(--ink); }
  .toc-item.active { color: var(--accent); border-left-color: var(--accent); }
</style>

<script>
  let tocObs: IntersectionObserver | undefined;

  function initToc() {
    tocObs?.disconnect();
    const toc = document.querySelector('[data-toc]');
    if (!toc) return;
    const links = [...toc.querySelectorAll('.toc-item')] as HTMLElement[];

    // 点击章节平滑滚动，但用 replaceState 避免在浏览器历史里堆叠锚点
    // （否则「后退」会退回上一处滚动位置而非上一页）
    links.forEach((l) => {
      l.addEventListener('click', (e) => {
        const id = l.dataset.target;
        const el = id ? document.getElementById(id) : null;
        if (!el) return;
        e.preventDefault();
        el.scrollIntoView({ behavior: 'smooth' });
        history.replaceState(history.state, '', `#${id}`);
      });
    });

    const targets = links
      .map((l) => document.getElementById(l.dataset.target!))
      .filter(Boolean) as HTMLElement[];
    tocObs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.toggle('active', l.dataset.target === e.target.id));
          }
        }
      },
      { rootMargin: '-72px 0px -70% 0px' }
    );
    targets.forEach((t) => tocObs!.observe(t));
  }

  initToc();
  document.addEventListener('astro:page-load', initToc);
</script>
