---
import Base from '../layouts/Base.astro';
import { getPosts } from '../lib/posts';
import { SECTIONS } from '../config';
import { formatCnDate } from '../lib/format-date';

const all = await getPosts();
const posts = all.slice(0, 24);

function makeRng(seed: number) {
  let s = (seed * 9301 + 49297) % 233280;
  return () => {
    s = (s * 9301 + 49297) % 233280;
    return s / 233280;
  };
}
const stars = posts.map((post, i) => {
  const r = makeRng(i + 7);
  const size = i === 0 ? 34 : Math.round(20 + r() * 13);
  return { post, size };
});
---
<Base>
  <main class="container home">
    <header class="intro">
      <p class="epigraph"><span class="oq">“</span>Homo sum, humani nihil a me alienum puto.</p>
      <div class="attrib"><span class="rule"></span>Terence</div>
    </header>

    <!-- 漂浮标题星图（宽屏 + 允许动效时由 JS 启用；漂浮由 CSS 合成器动画完成） -->
    <div class="stage" data-stage>
      {stars.map((s) => (
        <a class="star" href={`/${s.post.id}/`} style={`font-size:${s.size}px`}>
          <span class="star-label">{s.post.data.title}</span>
        </a>
      ))}
    </div>

    <!-- 默认 / 手机 / 减动效 / 无 JS：整洁列表 -->
    <section class="fallback">
      <div class="label">最新文章</div>
      <div class="feed">
        {posts.map((post) => (
          <a class="entry" href={`/${post.id}/`}>
            <div class="meta">{SECTIONS[post.section].name} · {formatCnDate(post.data.date)}</div>
            <h2 class="title">{post.data.title}</h2>
            {post.data.summary && <p class="summary">{post.data.summary}</p>}
          </a>
        ))}
      </div>
    </section>

    <a class="more" href="/archives/">全部文章 →</a>
  </main>
</Base>

<style>
  /* 题词：整句不换行（仅作者行单独一行） */
  .intro { width: fit-content; max-width: 100%; padding-top: 80px; }
  .epigraph {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: clamp(24px, 4.1vw, 42px); line-height: 1.2; color: var(--ink);
    margin: 0; white-space: nowrap; letter-spacing: 0.004em;
  }
  .oq { color: var(--accent); font-size: 1.35em; line-height: 0; vertical-align: -0.2em; margin-right: 0.02em; }
  .attrib {
    display: flex; align-items: center; justify-content: flex-end; gap: 12px;
    font-family: var(--font-display); font-style: italic; font-weight: 500;
    font-size: 19px; color: var(--dim); margin-top: 20px;
  }
  .attrib .rule { width: 42px; height: 1px; background: var(--accent-soft); }

  /* 星图舞台：题词下方区域，默认隐藏，JS 在宽屏 + 允许动效时启用 */
  .stage { position: relative; min-height: 58vh; margin-top: 44px; display: none; }
  .home.constellation-on .stage { display: block; }
  .home.constellation-on .fallback { display: none; }

  .star {
    position: absolute; max-width: 14em; text-align: center; text-decoration: none;
    animation: drift var(--dur, 22s) ease-in-out var(--delay, 0s) infinite;
  }
  @keyframes drift {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(var(--ax, 0px), var(--by, 0px)); }
    50% { transform: translate(var(--bx, 0px), var(--ay, 0px)); }
    75% { transform: translate(var(--cx, 0px), var(--cy, 0px)); }
  }
  .star-label {
    display: inline-block; font-family: var(--font-serif); font-weight: 600;
    line-height: 1.35; color: var(--ink);
    transition: transform 0.28s ease, color 0.28s ease;
  }
  .star:hover, .star:focus-visible { z-index: 5; outline: none; }
  .star:hover .star-label, .star:focus-visible .star-label { transform: scale(1.09); color: var(--accent); }

  /* 列表（默认可见） */
  .fallback { display: block; max-width: 720px; }
  .label {
    font-family: var(--font-ui); font-size: 12px; letter-spacing: 0.16em;
    color: var(--faint); padding-bottom: 14px; border-bottom: 1px solid var(--ink);
  }
  .entry { display: block; text-decoration: none; padding: 30px 0; border-top: 1px solid var(--hair); }
  .feed .entry:first-child { border-top: 0; }
  .meta { font-family: var(--font-ui); font-size: 12.5px; letter-spacing: 0.06em; color: var(--faint); }
  .title {
    font-family: var(--font-serif); font-weight: 600; font-size: 21px;
    line-height: 1.5; margin: 12px 0 0; color: var(--ink); transition: color 0.18s;
  }
  .summary {
    font-family: var(--font-serif); font-size: 15px; color: var(--dim);
    line-height: 1.9; margin: 10px 0 0; max-width: 40em;
  }
  .entry:hover .title { color: var(--accent); }

  .more {
    display: inline-block; margin-top: 40px;
    font-family: var(--font-ui); font-size: 13px; letter-spacing: 0.08em;
    color: var(--dim); text-decoration: none;
  }
  .more:hover { color: var(--accent); }

  /* 手机：题词允许换行，避免溢出 */
  @media (max-width: 860px) {
    .intro { width: auto; max-width: 560px; padding-top: 52px; }
    .epigraph { white-space: normal; }
  }
</style>

<script>
  import { place } from '../lib/constellation';

  let onResize: (() => void) | null = null;

  function stop() {
    if (onResize) { removeEventListener('resize', onResize); onResize = null; }
    document.querySelector('.home')?.classList.remove('constellation-on');
  }

  function start() {
    stop();
    const home = document.querySelector('.home');
    const stage = document.querySelector('[data-stage]') as HTMLElement | null;
    if (!home || !stage) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (innerWidth <= 860) return;

    home.classList.add('constellation-on');
    const els = [...stage.querySelectorAll('.star')] as HTMLElement[];
    if (!els.length) return;

    const W = stage.clientWidth;
    const H = stage.clientHeight;
    const amp = 24; // 漂浮幅度
    const pad = 14;

    // 用"含漂浮余量"的盒子布点，保证漂浮时也不重叠
    const items = els.map((el) => {
      const r = el.getBoundingClientRect();
      return { el, w: r.width + amp * 2, h: r.height + amp * 2, x: 0, y: 0 };
    });
    place(items, W, H, pad);

    const rnd = (m: number) => ((Math.random() * 2 - 1) * m).toFixed(1) + 'px';
    for (const it of items) {
      const el = it.el;
      el.style.left = `${it.x + amp}px`;
      el.style.top = `${it.y + amp}px`;
      el.style.setProperty('--ax', rnd(amp));
      el.style.setProperty('--ay', rnd(amp));
      el.style.setProperty('--bx', rnd(amp));
      el.style.setProperty('--by', rnd(amp));
      el.style.setProperty('--cx', rnd(amp));
      el.style.setProperty('--cy', rnd(amp));
      el.style.setProperty('--dur', `${(20 + Math.random() * 14).toFixed(1)}s`);
      el.style.setProperty('--delay', `${(-Math.random() * 24).toFixed(1)}s`);
    }

    let t: ReturnType<typeof setTimeout>;
    onResize = () => { clearTimeout(t); t = setTimeout(start, 250); };
    addEventListener('resize', onResize);
  }

  document.addEventListener('astro:page-load', start);
  document.addEventListener('astro:before-swap', stop);
</script>
