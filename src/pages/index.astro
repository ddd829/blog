---
import Base from '../layouts/Base.astro';
import PostIndex from '../components/PostIndex.astro';
import { getPosts } from '../lib/posts';
import { postNumber } from '../lib/numbering';
import { SECTIONS } from '../config';
import { formatCnDate } from '../lib/format-date';

const all = await getPosts();
const [hero, ...rest] = all;
const recent = rest.slice(0, 10);
---
<Base>
  <main class="container">
    {hero && (
      <section class="hero">
        <div class="kicker">N° {String(postNumber(hero, all)).padStart(3, '0')} · {SECTIONS[hero.section].name} · {formatCnDate(hero.data.date)}</div>
        <h1 class="hero-title"><a href={`/${hero.id}/`}>{hero.data.title}</a></h1>
        {hero.data.summary && (
          <div class="hero-lead">
            <span class="rule"></span>
            <p>{hero.data.summary}</p>
          </div>
        )}
      </section>
    )}
    <section class="recent">
      <PostIndex posts={recent} all={all} />
      <a class="more meta-ui" href="/archives/">全部文章 →</a>
    </section>
  </main>
</Base>

<style>
  .hero { padding: 84px 0 96px; }
  .hero-title { margin: 18px 0 0; max-width: 17em; }
  .hero-title a {
    font-family: var(--font-display);
    font-size: clamp(34px, 5.4vw, 60px);
    line-height: 1.16; font-weight: 500; text-decoration: none;
  }
  .hero-title a:hover { color: var(--accent); }
  .hero-lead { display: flex; gap: 48px; margin-top: 34px; align-items: baseline; }
  .rule { width: 64px; height: 1px; background: var(--ink); flex-shrink: 0; }
  .hero-lead p {
    font-family: var(--font-ui); font-weight: 300; font-size: 14.5px;
    line-height: 2; color: var(--dim); max-width: 34em; margin: 0;
  }
  .more { display: inline-block; margin-top: 26px; text-decoration: none; letter-spacing: 0.1em; }
  .more:hover { color: var(--accent); }
  @media (max-width: 720px) { .hero { padding: 48px 0 56px; } .hero-lead { gap: 20px; } }
</style>
