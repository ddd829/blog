---
import Base from '../layouts/Base.astro';
import { getPosts } from '../lib/posts';
import { SECTIONS } from '../config';
import { formatCnDate } from '../lib/format-date';

const all = await getPosts();
const posts = all.slice(0, 12);
---
<Base>
  <main class="container">
    <header class="intro">
      <p class="epigraph">Homo sum, humani nihil a me alienum puto.</p>
      <div class="attrib">— Terence</div>
    </header>

    <section class="latest">
      <div class="label">最新文章</div>
      <div class="feed">
        {posts.map((post) => (
          <a class="entry" href={`/${post.id}/`}>
            <div class="meta">{SECTIONS[post.section].name} · {formatCnDate(post.data.date)}</div>
            <h2 class="title">{post.data.title}</h2>
            {post.data.summary && <p class="summary">{post.data.summary}</p>}
          </a>
        ))}
      </div>
      <a class="more" href="/archives/">全部文章 →</a>
    </section>
  </main>
</Base>

<style>
  /* 题词 */
  .intro { max-width: 760px; padding: 88px 0 0; }
  .epigraph {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: clamp(27px, 3.7vw, 39px); line-height: 1.38; color: var(--ink);
    margin: 0; max-width: 15em;
  }
  .attrib {
    font-family: var(--font-ui); font-size: 13px; letter-spacing: 0.12em;
    color: var(--faint); margin-top: 20px;
  }

  /* 最新文章 */
  .latest { max-width: 720px; margin-top: 68px; }
  .label {
    font-family: var(--font-ui); font-size: 12px; letter-spacing: 0.16em;
    color: var(--faint); padding-bottom: 14px; border-bottom: 1px solid var(--ink);
  }

  .entry {
    display: block; text-decoration: none;
    padding: 30px 0; border-top: 1px solid var(--hair);
  }
  .feed .entry:first-child { border-top: 0; }
  .meta {
    font-family: var(--font-ui); font-size: 12.5px; letter-spacing: 0.06em;
    color: var(--faint);
  }
  .title {
    font-family: var(--font-serif); font-weight: 600; font-size: 21px;
    line-height: 1.5; margin: 12px 0 0; color: var(--ink); transition: color 0.18s;
  }
  .summary {
    font-family: var(--font-serif); font-size: 15px; color: var(--dim);
    line-height: 1.9; margin: 10px 0 0; max-width: 40em;
  }
  .entry:hover .title { color: var(--accent); }

  .more {
    display: inline-block; margin-top: 32px;
    font-family: var(--font-ui); font-size: 13px; letter-spacing: 0.08em;
    color: var(--dim); text-decoration: none;
  }
  .more:hover { color: var(--accent); }

  @media (max-width: 720px) {
    .intro { padding-top: 52px; }
    .latest { margin-top: 48px; }
  }
</style>
