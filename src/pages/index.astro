---
import Base from '../layouts/Base.astro';
import { getPosts } from '../lib/posts';
import { SECTIONS } from '../config';
import { formatCnDate } from '../lib/format-date';

const all = await getPosts();
const dotPosts = all.slice(0, 120);
const listPosts = all.slice(0, 30);

function makeRng(seed: number) {
  let s = (seed * 9301 + 49297) % 233280;
  return () => {
    s = (s * 9301 + 49297) % 233280;
    return s / 233280;
  };
}

// 文章星点：抖动网格布点（确定性、随文章数自适应），漂浮 + 标题若隐若现由 CSS 完成
const N = dotPosts.length;
const cols = Math.max(1, Math.round(Math.sqrt(N * 1.6)));
const rows = Math.max(1, Math.ceil(N / cols));
const nodes = dotPosts.map((post, i) => {
  const rng = makeRng(i * 17 + 5);
  const col = i % cols;
  const row = Math.floor(i / cols);
  const cellW = (100 - 20) / cols;
  const cellH = (100 - 20) / rows;
  const left = 10 + (col + 0.5) * cellW + (rng() - 0.5) * cellW * 0.6;
  const top = 10 + (row + 0.5) * cellH + (rng() - 0.5) * cellH * 0.6;
  return {
    post,
    left: +left.toFixed(2),
    top: +top.toFixed(2),
    ax: +((rng() * 2 - 1) * 24).toFixed(1),
    ay: +((rng() * 2 - 1) * 24).toFixed(1),
    bx: +((rng() * 2 - 1) * 24).toFixed(1),
    by: +((rng() * 2 - 1) * 24).toFixed(1),
    dur: +(7 + rng() * 5).toFixed(1),
    delay: +(-rng() * 12).toFixed(1),
    ldelay: +(-rng() * 11).toFixed(1),
    sz: +(4.5 + rng() * 2.5).toFixed(1),
  };
});

// 背景宇宙（暗色）：双层视差星尘，压暗压小，作为陪衬
const FW = 1000;
const FH = 600;
type Star = { x: number; y: number; r: number; o: number; c: string; dur: number; delay: number };
function layer(
  n: number, rMin: number, rMax: number, oMin: number, oMax: number, palette: string[], seed: number,
): Star[] {
  const rng = makeRng(seed);
  return Array.from({ length: n }, () => ({
    x: +(rng() * FW).toFixed(1),
    y: +(rng() * FH).toFixed(1),
    r: +(rMin + rng() * (rMax - rMin)).toFixed(2),
    o: +(oMin + rng() * (oMax - oMin)).toFixed(2),
    c: palette[(rng() * palette.length) | 0],
    dur: +(2.6 + rng() * 5).toFixed(1),
    delay: +(-rng() * 8).toFixed(1),
  }));
}
const farStars = layer(100, 0.3, 0.8, 0.1, 0.3, ['#c8d4ee', '#d6e0f4', '#bfcceb'], 99);
const nearStars = layer(22, 0.6, 1.4, 0.32, 0.62, ['#dfe7fb', '#cdd8f0', '#e7ddc8'], 51);

// 背景萤火（亮色）：暖金微光，压小压淡，作为陪衬
const fireflies = (() => {
  const rng = makeRng(77);
  return Array.from({ length: 34 }, () => ({
    x: +(rng() * 1000).toFixed(1),
    y: +(rng() * 600).toFixed(1),
    r: +(0.7 + rng() * 1.2).toFixed(2),
    o: +(0.26 + rng() * 0.4).toFixed(2),
    dur: +(2.6 + rng() * 4).toFixed(1),
    delay: +(-rng() * 8).toFixed(1),
  }));
})();
---
<Base>
  <main class="container home">
    <header class="intro">
      <p class="epigraph">
        <span class="l1"><span class="oq">“</span>Der bestirnte Himmel über mir</span>
        <span class="l2">und das moralische Gesetz in mir.</span>
      </p>
      <div class="attrib"><span class="rule"></span>Immanuel Kant</div>
    </header>

    <!-- 中间画布：背景（暗→宇宙 / 亮→暮山流萤）+ 文章星点。宽屏 + 允许动效时显示 -->
    <nav class="stage" aria-label="文章星图">
      <!-- 暗色：深空星尘 + 流星 -->
      <div class="cosmos" aria-hidden="true">
        <svg class="starfield far" viewBox={`0 0 ${FW} ${FH}`} preserveAspectRatio="xMidYMid slice">
          {farStars.map((s) => (
            <circle class="twinkle" cx={s.x} cy={s.y} r={s.r} fill={s.c} style={`--o:${s.o};animation-duration:${s.dur}s;animation-delay:${s.delay}s`} />
          ))}
        </svg>
        <svg class="starfield near" viewBox={`0 0 ${FW} ${FH}`} preserveAspectRatio="xMidYMid slice">
          {nearStars.map((s) => (
            <circle class="twinkle" cx={s.x} cy={s.y} r={s.r} fill={s.c} style={`--o:${s.o};animation-duration:${s.dur}s;animation-delay:${s.delay}s`} />
          ))}
        </svg>
        <div class="meteors">
          <div class="meteor" style="top:16%;left:6%;--ang:19deg;--dur:26s;--delay:-5s"><i></i></div>
          <div class="meteor" style="top:34%;left:50%;--ang:14deg;--dur:38s;--delay:-19s"><i></i></div>
        </div>
      </div>

      <!-- 亮色：素笔勾勒远山 + 萤火 -->
      <div class="duskscape" aria-hidden="true">
        <svg class="inkscape" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice">
          <defs>
            <filter id="inkSoft" x="-5%" y="-20%" width="110%" height="140%"><feGaussianBlur stdDeviation="0.7" /></filter>
          </defs>
          <g filter="url(#inkSoft)" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path class="ink ink-far" d="M-40,392 Q150,344 320,384 T660,374 T1000,382 T1240,372" />
            <path class="ink ink-mid" d="M-40,440 Q190,398 380,432 T760,424 T1240,430" />
            <path class="ink ink-near" d="M-40,486 Q170,452 410,480 T830,474 T1240,480" />
          </g>
        </svg>
        <svg class="fireflies" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice">
          {fireflies.map((f) => (
            <circle class="firefly twinkle" cx={f.x} cy={f.y} r={f.r} style={`--o:${f.o};animation-duration:${f.dur}s;animation-delay:${f.delay}s`} />
          ))}
        </svg>
      </div>

      {nodes.map((n) => (
        <a
          class="node"
          href={`/${n.post.id}/`}
          style={`left:${n.left}%;top:${n.top}%;--ax:${n.ax}px;--ay:${n.ay}px;--bx:${n.bx}px;--by:${n.by}px;--dur:${n.dur}s;--delay:${n.delay}s;--ldelay:${n.ldelay}s;--sz:${n.sz}px`}
        >
          <span class="dot"></span>
          <span class="node-label">{n.post.data.title}</span>
        </a>
      ))}
    </nav>

    <!-- 默认 / 手机 / 减动效 / 无 JS：整洁列表 -->
    <section class="fallback">
      <div class="label">最新文章</div>
      <div class="feed">
        {listPosts.map((post) => (
          <a class="entry" href={`/${post.id}/`}>
            <div class="meta">{SECTIONS[post.section].name} · {formatCnDate(post.data.date)}</div>
            <h2 class="title">{post.data.title}</h2>
            {post.data.summary && <p class="summary">{post.data.summary}</p>}
          </a>
        ))}
      </div>
    </section>

    <a class="more" href="/archives/">全部文章 →</a>
  </main>
</Base>

<style>
  /* 题词：错落两行（独立区域，背景不侵入） */
  .intro { width: fit-content; max-width: 100%; padding-top: 80px; position: relative; z-index: 1; }
  .epigraph {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: clamp(25px, 3.5vw, 40px); line-height: 1.3; color: var(--ink);
    margin: 0; letter-spacing: 0.004em;
  }
  .oq { color: var(--accent); font-size: 1.35em; line-height: 0; vertical-align: -0.2em; margin-right: 0.02em; }
  .epigraph .l1, .epigraph .l2 { display: block; }
  .epigraph .l2 { margin-left: 2.4em; }
  .attrib {
    display: flex; align-items: center; justify-content: flex-end; gap: 12px;
    font-family: var(--font-display); font-style: italic; font-weight: 500;
    font-size: 19px; color: var(--dim); margin-top: 20px;
  }
  .attrib .rule { width: 42px; height: 1px; background: var(--accent-soft); }

  /* 中间画布：默认隐藏，宽屏 + 允许动效显示 */
  .stage { position: relative; min-height: 60vh; margin-top: 52px; display: none; }

  /* 背景层：限定在画布内，四周径向遮罩柔化（无边界，不侵入题词/页脚） */
  .cosmos, .duskscape {
    position: absolute; inset: -4% -2%; z-index: 0; pointer-events: none;
    display: none; overflow: hidden;
    -webkit-mask-image: radial-gradient(125% 96% at 50% 48%, #000 50%, transparent 100%);
    mask-image: radial-gradient(125% 96% at 50% 48%, #000 50%, transparent 100%);
  }
  :global([data-theme='dark']) .cosmos { display: block; }
  :global([data-theme='light']) .duskscape { display: block; }

  /* 深空星尘 */
  .starfield {
    position: absolute; inset: -10px; width: calc(100% + 20px); height: calc(100% + 20px);
    pointer-events: none;
  }
  .starfield.far { animation: field-drift 150s ease-in-out infinite alternate; }
  .starfield.near { animation: field-drift-near 88s ease-in-out infinite alternate; }
  .starfield circle { opacity: var(--o, 0.3); }
  .twinkle { animation-name: twinkle; animation-timing-function: ease-in-out; animation-iteration-count: infinite; }
  @keyframes twinkle { 0%, 100% { opacity: var(--o); } 50% { opacity: calc(var(--o) * 0.3); } }
  @keyframes field-drift { from { transform: translate(0, 0); } to { transform: translate(-12px, -9px); } }
  @keyframes field-drift-near { from { transform: translate(0, 0); } to { transform: translate(-24px, -16px); } }

  /* 流星 */
  .meteors { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  .meteor { position: absolute; transform: rotate(var(--ang, 20deg)); }
  .meteor i {
    display: block; width: 150px; height: 1.4px; border-radius: 2px;
    background: linear-gradient(90deg, transparent, rgba(232, 240, 255, 0.9));
    filter: drop-shadow(0 0 3px rgba(210, 228, 255, 0.5));
    opacity: 0; animation: shoot var(--dur, 28s) linear var(--delay, 0s) infinite;
  }
  @keyframes shoot {
    0%, 2% { opacity: 0; transform: translateX(-180px); }
    3.5% { opacity: 1; }
    9% { opacity: 1; transform: translateX(64vw); }
    11%, 100% { opacity: 0; transform: translateX(72vw); }
  }

  /* 素笔勾勒远山：极淡墨线 + 微晕，缓慢明暗呼吸 */
  .inkscape { position: absolute; inset: 0; width: 100%; height: 100%; }
  .ink-far { stroke: #7c8693; stroke-width: 1.2; opacity: 0.22; animation: ink-breathe 16s ease-in-out infinite; }
  .ink-mid { stroke: #6b7682; stroke-width: 1.4; opacity: 0.28; animation: ink-breathe 20s ease-in-out infinite reverse; }
  .ink-near { stroke: #5c6571; stroke-width: 1.6; opacity: 0.34; animation: ink-breathe 24s ease-in-out infinite; }
  @keyframes ink-breathe { 0%, 100% { opacity: var(--op, 0.3); } 50% { opacity: calc(var(--op, 0.3) * 0.55); } }
  .ink-far { --op: 0.22; } .ink-mid { --op: 0.28; } .ink-near { --op: 0.34; }

  /* 萤火 */
  .fireflies {
    position: absolute; inset: -10px; width: calc(100% + 20px); height: calc(100% + 20px);
    animation: field-drift-near 70s ease-in-out infinite alternate;
  }
  .firefly { fill: #d8a35a; opacity: var(--o, 0.4); filter: drop-shadow(0 0 1.4px rgba(216, 163, 90, 0.7)); }

  /* 文章星点：唯一最亮、可点的光 */
  .node {
    position: absolute; text-decoration: none; z-index: 1;
    animation: node-drift var(--dur, 20s) ease-in-out var(--delay, 0s) infinite;
  }
  .dot {
    display: block; width: var(--sz, 5px); height: var(--sz, 5px);
    border-radius: 50%; background: var(--accent);
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    animation: dot-pulse 4.5s ease-in-out var(--delay, 0s) infinite;
  }
  :global([data-theme='dark']) .dot { box-shadow: 0 0 7px color-mix(in srgb, var(--accent) 75%, transparent); }
  :global([data-theme='light']) .dot { box-shadow: 0 0 8px color-mix(in srgb, #e2ad62 75%, transparent); }
  @keyframes dot-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.62; } }
  @keyframes node-drift {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(var(--ax, 0px), var(--ay, 0px)); }
    66% { transform: translate(var(--bx, 0px), var(--by, 0px)); }
  }

  /* 标题：随呼吸若隐若现，悬停 / 聚焦完全显现 */
  .node-label {
    position: absolute; left: 50%; bottom: 50%;
    transform: translate(-50%, -14px);
    white-space: nowrap;
    font-family: var(--font-serif); font-weight: 600; font-size: 15px; color: var(--ink);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border: 1px solid var(--hair); border-radius: 7px; padding: 5px 12px;
    opacity: 0; pointer-events: none;
    animation: label-ghost 11s ease-in-out var(--ldelay, 0s) infinite;
    transition: opacity 0.22s ease, transform 0.22s ease;
    backdrop-filter: blur(3px);
  }
  @keyframes label-ghost { 0%, 64%, 100% { opacity: 0; } 28%, 40% { opacity: 0.42; } }
  .node:hover, .node:focus-visible { z-index: 10; outline: none; }
  .node:hover .dot, .node:focus-visible .dot {
    transform: translate(-50%, -50%) scale(2.1); animation: none;
    box-shadow: 0 0 14px color-mix(in srgb, var(--accent) 85%, transparent);
  }
  .node:hover .node-label, .node:focus-visible .node-label {
    opacity: 1; transform: translate(-50%, -20px); animation: none;
  }

  /* 列表（默认可见） */
  .fallback { display: block; max-width: 720px; }
  .label {
    font-family: var(--font-ui); font-size: 12px; letter-spacing: 0.16em;
    color: var(--faint); padding-bottom: 14px; border-bottom: 1px solid var(--ink);
  }
  .entry { display: block; text-decoration: none; padding: 30px 0; border-top: 1px solid var(--hair); }
  .feed .entry:first-child { border-top: 0; }
  .meta { font-family: var(--font-ui); font-size: 12.5px; letter-spacing: 0.06em; color: var(--faint); }
  .title {
    font-family: var(--font-serif); font-weight: 600; font-size: 21px;
    line-height: 1.5; margin: 12px 0 0; color: var(--ink); transition: color 0.18s;
  }
  .summary {
    font-family: var(--font-serif); font-size: 15px; color: var(--dim);
    line-height: 1.9; margin: 10px 0 0; max-width: 40em;
  }
  .entry:hover .title { color: var(--accent); }

  .more {
    display: inline-block; margin-top: 40px; position: relative; z-index: 1;
    font-family: var(--font-ui); font-size: 13px; letter-spacing: 0.08em;
    color: var(--dim); text-decoration: none;
  }
  .more:hover { color: var(--accent); }

  /* 宽屏 + 允许动效：显示星图画布，隐藏列表 */
  @media (min-width: 861px) and (prefers-reduced-motion: no-preference) {
    .stage { display: block; }
    .fallback { display: none; }
  }

  /* 手机：题词缩进收紧 */
  @media (max-width: 860px) {
    .intro { width: auto; max-width: 560px; padding-top: 52px; }
    .epigraph .l2 { margin-left: 1.2em; }
  }
</style>
