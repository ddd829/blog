---
import Base from '../../layouts/Base.astro';
import { getPosts } from '../../lib/posts';
import { NAMESPACE_ORDER, namespaceLabel, parseTag } from '../../lib/tags';

const all = await getPosts();
const counts = new Map<string, number>();
for (const p of all) for (const t of p.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);

// 按命名空间（subject/ topic/ type/ project/ series/ source/）分组展示
type Tag = { tag: string; label: string; n: number };
const groups = new Map<string, Tag[]>();
for (const [tag, n] of counts) {
  const { ns, value } = parseTag(tag);
  if (!groups.has(ns)) groups.set(ns, []);
  groups.get(ns)!.push({ tag, label: value, n });
}
for (const arr of groups.values()) {
  arr.sort((a, b) => b.n - a.n || a.label.localeCompare(b.label));
}

const knownKeys = NAMESPACE_ORDER.filter((ns) => groups.has(ns));
const extraKeys = [...groups.keys()].filter((ns) => !NAMESPACE_ORDER.includes(ns as never)).sort();
const ordered = [...knownKeys, ...extraKeys].map((ns) => ({
  name: namespaceLabel(ns),
  tags: groups.get(ns)!,
}));
---
<Base title="标签" description="按主题浏览全部文章">
  <main class="container">
    <header class="head">
      <h1 class="name">标签</h1>
      <p class="meta-ui">
        {counts.size} 个标签 · {all.length} 篇文章 ·
        <a class="back" href="/archives/">按时间浏览 →</a>
      </p>
    </header>

    {ordered.map((g) => (
      <section class="group">
        <div class="glabel">{g.name}</div>
        <div class="tags">
          {g.tags.map((t) => (
            <a class="tag" href={`/tags/${t.tag}/`}>
              {t.label}{t.n > 1 && <span class="n">{t.n}</span>}
            </a>
          ))}
        </div>
      </section>
    ))}
  </main>
</Base>

<style>
  .head { padding: 64px 0 28px; }
  .name { font-family: var(--font-display); font-size: 44px; font-weight: 500; margin: 0 0 12px; }
  .back { color: var(--dim); text-decoration: none; }
  .back:hover { color: var(--accent); }

  .group {
    display: grid; grid-template-columns: 110px 1fr; gap: 28px;
    padding: 26px 0; border-top: 1px solid var(--hair); align-items: start;
  }
  .glabel {
    font-family: var(--font-display); font-size: 22px; font-weight: 500;
    color: var(--ink); padding-top: 2px; line-height: 1.2;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 10px; }
  .tag {
    display: inline-flex; align-items: baseline; gap: 6px;
    font-family: var(--font-ui); font-size: 13.5px; color: var(--dim);
    text-decoration: none; background: var(--chip-bg);
    border: 1px solid var(--chip-border); border-radius: 99px; padding: 6px 14px;
    transition: border-color 0.18s, color 0.18s;
  }
  .tag:hover { color: var(--accent); border-color: var(--accent-soft); }
  .tag .n { font-size: 11px; color: var(--faint); }

  @media (max-width: 720px) {
    .group { grid-template-columns: 1fr; gap: 12px; }
    .glabel { padding-top: 0; }
  }
</style>
